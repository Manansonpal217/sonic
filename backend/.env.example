# Django Settings
SECRET_KEY=django-insecure-change-this-in-production
DEBUG=True
# When testing mobile app on a physical device, add your machine's LAN IP so the API accepts requests.
# Use the same IP as EXPO_PUBLIC_API_BASE_URL in the app's .env (e.g. http://192.168.1.5:8000/app).
# Example with machine IPs: ALLOWED_HOSTS=localhost,127.0.0.1,0.0.0.0,10.100.68.213,192.168.232.24
# Production: ALLOWED_HOSTS=your-app.ondigitalocean.app
ALLOWED_HOSTS=localhost,127.0.0.1,0.0.0.0

# Database Configuration
# Optional: set DATABASE_URL to use a single URL (e.g. on DigitalOcean App Platform: ${sonic-db.DATABASE_URL}); overrides DB_* below.
# For Docker Compose/Kubernetes: set DB_HOST to the database service name (e.g. db or postgres), not localhost.
DATABASE_URL=
DB_NAME=sonic_db
DB_USER=sonic_user
DB_PASSWORD=sonic_password
DB_HOST=localhost
DB_PORT=5432

# Redis (for Channels/WebSockets in production) – DigitalOcean: ${sonic-redis.REDIS_URL}
REDIS_URL=

# CORS Settings – add your machine's API origin so the mobile app can call the API.
# Example with machine IPs: add http://YOUR_IP:8000 for each (e.g. http://10.100.68.213:8000,http://192.168.232.24:8000)
# Production: CORS_ALLOWED_ORIGINS=https://your-frontend.com,https://your-app.ondigitalocean.app
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:8081

# CSRF – in production, add your frontend and API URLs
# Production: CSRF_TRUSTED_ORIGINS=https://your-frontend.com,https://your-app.ondigitalocean.app
CSRF_TRUSTED_ORIGINS=http://localhost:3000,http://localhost:8081

# Pearl SMS (OTP). Set PEARLSMS_API_KEY in .env; sender ID must be registered with Pearl SMS.
# PEARLSMS_API_KEY=your_pearlsms_api_key
# PEARLSMS_SENDER=SONIC
# PEARLSMS_BASE_URL=http://sms.pearlsms.com/public/sms/send
