# Admin Panel – Environment Variables
# Copy to .env.local for local dev. For Vercel, add these in Project Settings → Environment Variables.

# Production (Vercel) – point to your DigitalOcean backend
NEXT_PUBLIC_API_BASE_URL=https://your-app.ondigitalocean.app/api
NEXT_PUBLIC_MEDIA_BASE_URL=https://your-app.ondigitalocean.app/media

# Optional: fallback for images when local media returns 404 (local dev only)
# NEXT_PUBLIC_MEDIA_FALLBACK_BASE_URL=https://your-app.ondigitalocean.app
