  "devDependencies": {
    "@babel/core": "^7.24.0",
    "@types/react": "~18.2.79",
    "babel-plugin-module-resolver": "^4.1.0",
    "patch-package": "^8.0.1",
    "react-native-svg-transformer": "^1.5.2",
    "sharp": "^0.34.5",
    "typescript": "~5.3.3"
