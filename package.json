{
  "name": "inara-app",
  "version": "1.0.0",
  "main": "node_modules/expo/AppEntry.js",
  "scripts": {
    "start": "expo start --port 3000",
    "android": "expo run:android --port 3000",
    "ios": "expo run:ios --port 3000",
    "web": "expo start --web --port 3000",
    "build:android": "eas build --platform android",
    "build:ios": "eas build --platform ios",
    "build:all": "eas build --platform all",
    "check:api": "./scripts/check-backend-connectivity.sh",
    "generate-icons": "node scripts/generate-app-icons.js",
    "postinstall": "node scripts/copy-expo-gradle-plugin.js && node scripts/patch-expo-compose-plugin.js"
  },
  "dependencies": {
    "@react-native-async-storage/async-storage": "1.23.1",
    "@react-navigation/native": "^6.1.18",
    "@react-navigation/native-stack": "^6.11.0",
    "@shopify/restyle": "^1.6.1",
    "axios": "^1.6.0",
    "expo": "~51.0.0",
    "expo-camera": "~15.0.16",
    "expo-dev-client": "~4.0.29",
    "expo-font": "~12.0.9",
    "expo-location": "~17.0.1",
    "expo-status-bar": "~1.12.1",
    "mobx": "^6.13.0",
    "mobx-react-lite": "^4.0.7",
    "react": "18.2.0",
    "react-hook-form": "^7.22.3",
    "react-native": "0.74.5",
    "react-native-device-info": "^10.14.0",
