# Expo/React Native app – optional override for API base URL
# Only needed when testing on a physical device (same WiFi as your Mac).
# Leave unset to use defaults: iOS Simulator → localhost, Android Emulator → 10.0.2.2
#
# For physical device: set to your machine's LAN IP. The same IP must be in
# backend ALLOWED_HOSTS and CORS_ALLOWED_ORIGINS (see backend/.env.example).
# Example – use the IP your phone uses to reach this Mac (run `ifconfig | grep 'inet '` to see IPs):
# EXPO_PUBLIC_API_BASE_URL=http://192.168.232.24:8000/app
